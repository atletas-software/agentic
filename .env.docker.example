# Copy to ".env.docker" for docker-compose usage.
# Keep your existing OAuth/destination values from .env, then update these:

# Host path to your Google service-account credential JSON
GOOGLE_CREDENTIALS_FILE_HOST=./credentials.json

# Container-internal DB/Redis URLs (recommended defaults for compose services)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_prod_db_password
POSTGRES_DB=athlete
DATABASE_URL_DOCKER=postgresql://postgres:change_this_prod_db_password@postgres:5432/athlete
REDIS_URL_DOCKER=redis://redis:6379/0

# Credential path inside containers (mounted read-only by compose)
DESTINATION_GOOGLE_CREDENTIALS_FILE_DOCKER=/run/secrets/google-credentials.json

# API process workers
WEB_CONCURRENCY=2
